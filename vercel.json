{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd RoboCount && npm run build",
  "installCommand": "cd RoboCount && npm install",
  "outputDirectory": "RoboCount/dist",
  "functions": {
    "RoboCount/api/index.py": {
      "excludeFiles": "{RoboCount/src/**,RoboCount/node_modules/**,RoboCount/dist/**,RoboCount/.venv/**,RoboCount/__pycache__/**,RoboCount/**/__pycache__/**,RoboCount/**/*.pyc,RoboCount/**/*.pyo,RoboCount/.pytest_cache/**,RoboCount/.mypy_cache/**,RoboCount/.ruff_cache/**,.git/**,.vercel/**,RoboCount/.vercel/**,**/pandas/tests/**,**/numpy/**/tests/**,**/numpy/tests/**,**/reportlab/**,**/reportlab-*.dist-info/**,**/uvicorn/**,**/uvicorn-*.dist-info/**,**/dotenv/**,**/python_dotenv-*.dist-info/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/RoboCount/api/index.py"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
